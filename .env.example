# ── AIO Training — environment template ─────────────────────────────────────
# Copy to .env.local (dev) or set these on your host (production).
# Every variable here is REQUIRED unless noted.

# SQLite database file. Relative paths resolve against the project root.
# Production: keep the same value; back the file up regularly.
DATABASE_URL="file:./dev.db"

# Admin session signing key — min 32 chars. The app refuses to boot without it.
# Generate: openssl rand -hex 32
SESSION_SECRET=""

# Admin portal credentials (the login at /admin).
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Stripe — used by the Football Skills Clinic checkout.
# Use sk_test_... keys in dev, sk_live_... in production.
STRIPE_SECRET_KEY=""
STRIPE_CLINIC_EARLY_PRICE_ID=""
STRIPE_CLINIC_STANDARD_PRICE_ID=""
