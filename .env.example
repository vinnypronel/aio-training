# ── AIO Training — environment template ─────────────────────────────────────
# Copy to .env.local (dev) or set these on your host (Vercel) for production.
# Every variable here is REQUIRED unless marked optional.

# ── Database (Neon Postgres) ────────────────────────────────────────────────
# DATABASE_URL: pooled connection string (…-pooler…) used at runtime.
# DIRECT_URL:   direct connection string (no -pooler) used for migrations.
# Get both from the Neon dashboard / Vercel Neon integration.
DATABASE_URL=""
DIRECT_URL=""

# ── Admin auth ──────────────────────────────────────────────────────────────
# SESSION_SECRET: min 32 chars, the app refuses to boot without it.
#   Generate: openssl rand -hex 32
SESSION_SECRET=""
# Admin portal login at /admin. Use a long, random ADMIN_PASSWORD (16+ chars).
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
# Optional second admin account. Leave blank to disable.
ADMIN_EMAIL_2=""
ADMIN_PASSWORD_2=""

# ── Stripe (Football Skills Clinic checkout) ────────────────────────────────
# Use sk_test_/pk_test_ keys in dev, live keys in production.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_CLINIC_EARLY_PRICE_ID=""
STRIPE_CLINIC_STANDARD_PRICE_ID=""
# From the Stripe webhook endpoint you register for /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=""

# ── File uploads (Vercel Blob) ──────────────────────────────────────────────
# Provided automatically by the Vercel Blob integration. When empty, admin
# flyer uploads fall back to writing into /public/assets/uploads (dev only).
BLOB_READ_WRITE_TOKEN=""

# ── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Provided by the Vercel Upstash integration. When empty, limiting falls back
# to in-memory (fine for a single local process, not for serverless).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Site / analytics (optional) ─────────────────────────────────────────────
# Canonical origin used as a fallback for Stripe return URLs.
NEXT_PUBLIC_SITE_URL="https://www.trainingaio.com"
# Meta Pixel numeric ID. Leave blank to keep the pixel disabled.
NEXT_PUBLIC_META_PIXEL_ID=""
